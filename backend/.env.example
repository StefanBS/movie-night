# Copy to .env (gitignored) before running just recipes.
DATABASE_URL=postgres://movie:movie@localhost:5432/movienight?sslmode=disable
# Comma-separated web origins allowed to call this API from a browser (CORS).
# Origins are matched exactly (scheme + host + port), and native apps and curl
# send no Origin and are unaffected. The Expo web dev server is
# http://localhost:8081 (it falls back to 8082+ if 8081 is busy — pin it with
# `expo start --port 8081`). To open the web build from another device on your
# LAN, add that origin too, e.g. http://192.168.1.50:8081 (note: http, not
# https — the dev server has no TLS). In prod, set this to your deployed web
# origin, e.g. https://movie-night.app
CORS_ALLOWED_ORIGINS=http://localhost:8081
# Rootless Podman users: uncomment the two lines below.
# export TESTCONTAINERS_RYUK_DISABLED=true
# export DOCKER_HOST=unix://$XDG_RUNTIME_DIR/podman/podman.sock
