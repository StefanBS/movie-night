set dotenv-load := true

# List all recipes
default:
    @just --list

# Start the postgres:18 container (detached)
db-up:
    docker compose up -d db

# Stop and remove the postgres container
db-down:
    docker compose down

# Destroy the postgres container and its data volume
db-reset:
    docker compose down -v

# Apply all goose migrations
migrate:
    go tool goose -dir migrations postgres "$DATABASE_URL" up

# Roll back the most recent goose migration
migrate-down:
    go tool goose -dir migrations postgres "$DATABASE_URL" down

# Load the dev seed (idempotent; NOT a migration)
seed:
    docker compose exec -T db psql -U movie -d movienight < seed.sql

# Regenerate the sqlc db package
sqlc:
    go tool sqlc generate

# Verify formatting with gofmt
fmt-check:
    test -z "$(gofmt -l .)" || { echo "Not gofmt-clean:"; gofmt -l .; exit 1; }

# Report suspicious constructs
vet:
    go vet ./...

# Compile all packages
build:
    go build ./...

# Run the fast unit tests
test:
    go test ./...

# Run all fast checks: formatting, vet, build, unit tests (what CI runs)
check: fmt-check vet build test

# Run the testcontainers integration tests
test-integration:
    go test -tags=integration ./...

# Scan dependencies for known vulnerabilities (reachable-only, near-zero false positives)
vuln:
    go tool govulncheck ./...

# Static security analysis (skips sqlc-generated files). gosec is a pinned binary, not a go tool — see CLAUDE.md.
sast:
    gosec -exclude-generated ./...

# Run all security scans, human-readable; fails if either scan does.
audit:
    #!/usr/bin/env bash
    # Both always run — a govulncheck failure must not mask gosec findings.
    set -uo pipefail
    rc=0
    just vuln || rc=1
    just sast || rc=1
    exit $rc

# Emit SARIF for the code-scanning upload AND gate it, each from a single scan run.
audit-sarif:
    #!/usr/bin/env bash
    # CI uploads the SARIF with `if: always()`, so findings still reach the Security
    # tab when this fails. gosec gates by exit code; govulncheck's SARIF mode always
    # exits 0, so gate on any reachable (error-level) finding — what text mode exits 3 for.
    set -uo pipefail
    rc=0
    gosec -exclude-generated -fmt sarif -out gosec.sarif ./... || rc=1
    go tool govulncheck -format sarif ./... > govulncheck.sarif || rc=1
    n=$(jq '[.runs[].results[] | select(.level == "error")] | length' govulncheck.sarif 2>/dev/null || echo 0)
    if [ "${n:-0}" -gt 0 ]; then
        echo "govulncheck: reachable vulnerabilities found (see govulncheck.sarif)" >&2
        rc=1
    fi
    exit $rc

# Run the backend server
run:
    go run .
